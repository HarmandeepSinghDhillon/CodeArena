{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/dashboard", "dest": "public/dashboard.html" },
    { "src": "/admin", "dest": "public/admin.html" },
    { "src": "/signup", "dest": "public/signup.html" },
    { "src": "/login", "dest": "public/index.html" },
    { "src": "/", "dest": "public/index.html" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}